{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "mlir",
      "camelcase": "MLIR",
      "title": "MLIR",
      "scope": "source.mlir",
      "file-types": ["mlir"],
      "injection-regex": "^mlir$",
      "class-name": "TreeSitterMlir"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "Apache-2.0 WITH LLVM-exception",
    "description": "MLIR grammar for tree-sitter",
    "authors": [
      {
        "name": "Buyun Xu",
        "email": "xubuyun@outlook.com",
        "url": "https://github.com/felixtensor"
      }
    ],
    "links": {
      "repository": "https://github.com/felixtensor/tree-sitter-mlir"
    }
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true,
    "zig": true
  }
}
